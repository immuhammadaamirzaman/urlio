# ShortlyX backend configuration. Copy to `.env` and adjust.
# Every variable maps to a field on app.core.config.Settings.

# --- App / meta ---
PROJECT_NAME=ShortlyX
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
BASE_URL=http://localhost:8000

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_JSON=true
# Comma-separated IPs/CIDRs of reverse proxies allowed to set X-Forwarded-For.
# Leave empty to ignore X-Forwarded-For entirely (direct-to-app deployments).
# Example behind a load balancer: TRUSTED_PROXIES=10.0.0.0/8
TRUSTED_PROXIES=

# --- Database ---
# Provide the POSTGRES_* parts and the app assembles an async SQLAlchemy URL from them.
# Alternatively set DATABASE_URL directly (it takes precedence over the parts below),
# e.g. DATABASE_URL=postgresql+asyncpg://shortlyx:shortlyx@db:5432/shortlyx
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shortlyx
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL_SECONDS=86400
NEGATIVE_CACHE_TTL_SECONDS=30
CLICK_STREAM_KEY=clicks:stream
CLICK_STREAM_MAXLEN=1000000
CLICK_CONSUMER_GROUP=clickflush
CLICK_FLUSH_BATCH=500
CLICK_FLUSH_ENABLED=true
CLICK_FLUSH_INTERVAL_SECONDS=5

# --- Security / JWT ---
# CHANGE THIS in production: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=CHANGE_ME_DEV_SECRET_NOT_FOR_PROD
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=shortlyx
JWT_AUDIENCE=shortlyx-api
LINK_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# --- Password hashing (argon2id) ---
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# --- Shortcode generation ---
SHORTCODE_LENGTH=7
SHORTCODE_MAX_LENGTH=12
SHORTCODE_ALPHABET=0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz
SHORTCODE_MAX_RETRIES=5
CUSTOM_ALIAS_MIN_LENGTH=3
CUSTOM_ALIAS_MAX_LENGTH=64

# --- URL validation / SSRF ---
MAX_URL_LENGTH=2048
ALLOWED_URL_SCHEMES=http,https
SSRF_PROTECTION_ENABLED=true
SSRF_ALLOW_PRIVATE_HOSTS=false
SSRF_HOST_ALLOWLIST=

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANON_PER_MINUTE=30
RATE_LIMIT_ANON_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=120
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_REDIRECT_ANON_PER_MINUTE=300
RATE_LIMIT_REDIRECT_WINDOW_SECONDS=60

# --- Redirect ---
REDIRECT_STATUS_CODE=307

# --- CORS / security headers ---
# The API uses Bearer-header auth (no cookies), so credentialed CORS stays off.
# If you enable CORS_ALLOW_CREDENTIALS, CORS_ORIGINS must be an explicit list (not *).
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
SECURITY_HEADERS_ENABLED=true

# --- Pagination ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
